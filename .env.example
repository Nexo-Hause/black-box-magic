# Gemini API key (Google AI Studio)
GOOGLE_AI_API_KEY=your-google-ai-api-key

# API keys for clients (comma-separated, format: label:key)
BBM_API_KEYS=test:sk-test-key-change-me

# Supabase (usage logging)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cookie signing secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
BBM_COOKIE_SECRET=your-random-secret-32-chars-minimum

# JWT secret for onboarding tokens (optional — falls back to BBM_COOKIE_SECRET via HMAC derivation)
# BBM_JWT_SECRET=your-separate-jwt-secret

# SMTP for email results (Google Workspace)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-email@example.com
SMTP_PASS=your-google-app-password

# Ubiqo Evidence API (Spec 00 + Spec 02)
UBIQO_API_TOKEN=your-ubiqo-bearer-token
UBIQO_API_BASE=https://bi.ubiqo.net
UBIQO_PHOTO_DOMAINS=d1g2sa7lgddaom.cloudfront.net
UBIQO_QSR_CUSTOM_RULES=

# Firma encryption key — encrypts CloudFront signed credentials at rest (AES-256-GCM)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Optional: if not set, firma is stored in plaintext (acceptable for dev, not for prod)
# BBM_FIRMA_ENCRYPTION_KEY=your-64-char-hex-key

# Ubiqo Webhook (Spec 02 Phase 2 — not yet active)
# UBIQO_WEBHOOK_SECRET=your-webhook-secret-32-chars-minimum

# Dashboard access (comma-separated emails)
# DASHBOARD_ALLOWED_EMAILS=user@example.com

# Admin email
# BBM_ADMIN_EMAIL=admin@example.com
